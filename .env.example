# Robokassa credentials from Settings → Technical settings.
# Keep real values only in `.env`; never commit that file.
ROBOKASSA_MERCHANT_LOGIN=YOUR_ROBOKASSA_STORE_LOGIN
ROBOKASSA_PASSWORD_1=YOUR_ROBOKASSA_PASSWORD_1
ROBOKASSA_PASSWORD_2=YOUR_ROBOKASSA_PASSWORD_2

# Must match the hashing algorithm selected in the Robokassa dashboard.
ROBOKASSA_HASH_ALGORITHM=md5

# true while testing the integration; false after activating production payments.
ROBOKASSA_TEST_MODE=true

# Usually this URL should not be changed.
ROBOKASSA_PAYMENT_URL=https://auth.robokassa.ru/Merchant/Payment/Index
